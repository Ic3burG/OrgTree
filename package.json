{
  "name": "org-directory-tree",
  "version": "1.0.0",
  "description": "Interactive hierarchical organization directory with tree-style navigation",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:all": "npm test && cd server && npm test",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,md,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,css,md,html}\"",
    "lint:all": "npm run lint && cd server && npm run lint",
    "typecheck": "tsc --noEmit",
    "sdk:generate": "openapi-typescript server/src/openapi.yaml -o src/sdk/api-types.ts",
    "prepare": "node -e \"process.exit(process.env.CI ? 0 : 1)\" || husky",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:chromium": "playwright test --project=chromium"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{json,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@sentry/react": "^10.43.0",
    "@simplewebauthn/browser": "^13.3.0",
    "dagre": "^0.8.5",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "papaparse": "^5.4.1",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.0",
    "socket.io-client": "^4.8.3",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dagre": "^0.7.54",
    "@types/jszip": "^3.4.1",
    "@types/node": "^25.5.0",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode.react": "^3.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.52.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "happy-dom": "^20.8.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.16"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.59.0",
    "@rollup/rollup-darwin-x64": "^4.59.0"
  }
}
